# Public, embedded into the client bundle. Safe to commit only via .env.example.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc... (anon public key)

# Server-only. NEVER commit. Used by server actions to write to pa_waitlist and pa_tool_queries.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc... (service role key)

# Resend transactional email
RESEND_API_KEY=re_...
RESEND_FROM=Joshua at PatronAtlas <info@patronatlas.com.au>

# OpenRouter (for the AI matching engine at /tool route)
# Free model in use: openai/gpt-oss-120b:free. No cost while it remains free.
# If swapping to a paid model, also bump the cost estimate in src/lib/match-funds.ts.
OPENROUTER_API_KEY=sk-or-v1-...
