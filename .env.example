# Public, embedded into the client bundle. Safe to commit only via .env.example.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc... (anon public key)

# Server-only. NEVER commit. Used by server actions to write to pa_waitlist and pa_tool_queries.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc... (service role key)

# Resend transactional email
RESEND_API_KEY=re_...
RESEND_FROM=Joshua at PatronAtlas <info@patronatlas.com.au>

# OpenRouter (for the AI matching engine at /tool/run)
# Primary: deepseek/deepseek-v4-flash:free  (shared rate-limit pool, fails in bursts)
# Paid fallback: deepseek/deepseek-v4-flash  (~USD 0.0043 per match; needs account credit)
# Both rows benchmarked zero hallucinated ABNs; ABN integrity guard in
# match-funds.ts:attachContacts() drops any fund whose ABN is not in the dataset
# regardless of which model produced it. If swapping models, also revisit that
# guard plus the per-call cost estimate.
OPENROUTER_API_KEY=sk-or-v1-...
